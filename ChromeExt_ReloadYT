// manifest.json
{
  "manifest_version": 3,
  "name": "YouTube Ad Detector",
  "version": "1.0",
  "description": "Detects YouTube ads and reloads the page after 1 second.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}

// background.js
chrome.tabs.onCreated.addListener(function(tab) {
  chrome.scripting.executeScript({
    target: { tabId: tab.id },
    function: detectAd
  });
});

function detectAd() {
  const adElements = document.querySelectorAll('iframe');
  if (adElements.length > 0) {
    setTimeout(reloadPage, 1000);
  }
}

function reloadPage() {
  chrome.tabs.reload(null, { force: true });
}


